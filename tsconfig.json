{
	"compilerOptions": {
		"strict": true,
		"types": ["node"],
		"esModuleInterop": true,
		"noEmit": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"allowImportingTsExtensions": true
	},
	"include": ["*.ts", "src/**/*.ts", "tests/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
